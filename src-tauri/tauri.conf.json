{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Todo Desktop",
  "version": "0.1.0",
  "identifier": "com.tauri.dev",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev --host 0.0.0.0 --port 1420",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "ball",
        "title": "Todo Ball",
        "width": 96,
        "height": 96,
        "minWidth": 96,
        "minHeight": 96,
        "maxWidth": 96,
        "maxHeight": 96,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": true,
        "visible": true,
        "url": "ball.html"
      },
      {
        "label": "panel",
        "title": "Todo Desktop",
        "width": 920,
        "height": 780,
        "minWidth": 720,
        "minHeight": 620,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": false,
        "shadow": true,
        "visible": false,
        "url": "panel.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
